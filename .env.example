# ==========================================================
# Velora
# Environment Configuration
# ==========================================================
#
# Copy this file to ".env" before running the project.
#
# Windows:
#   copy .env.example .env
#
# Linux / macOS:
#   cp .env.example .env
#
# ==========================================================

# ==========================================================
# Application
# ==========================================================

APP_NAME=Velora
APP_ENV=development
APP_PORT=18080
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta

# ==========================================================
# AI
# ==========================================================

AI_PROVIDER=ollama
AI_TIMEOUT=120s
AI_MAX_RETRIES=2

# ==========================================================
# PostgreSQL
# ==========================================================

DB_HOST=localhost
DB_PORT=15432
DB_NAME=velora
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Jakarta

# ==========================================================
# Redis
# ==========================================================

REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================================
# MinIO
# ==========================================================

MINIO_ENDPOINT=localhost:19000
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001

MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123

MINIO_BUCKET=velora
MINIO_USE_SSL=false

# ==========================================================
# JWT
# ==========================================================

JWT_SECRET=CHANGE_ME_IN_PRODUCTION

JWT_ACCESS_TOKEN_EXPIRES=24h
JWT_REFRESH_TOKEN_EXPIRES=168h

# ==========================================================
# Mailpit
# ==========================================================

SMTP_HOST=localhost
SMTP_PORT=11025

MAILPIT_WEB_PORT=18025

SMTP_USERNAME=
SMTP_PASSWORD=

SMTP_FROM_NAME=Velora
SMTP_FROM_EMAIL=noreply@velora.local

# ==========================================================
# Ollama
# ==========================================================

OLLAMA_URL=http://localhost:11434
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen2.5-kunou-14b
OLLAMA_TIMEOUT=120

# ==========================================================
# Logging
# ==========================================================

LOG_LEVEL=debug
LOG_FORMAT=text

# ==========================================================
# Upload
# ==========================================================

UPLOAD_MAX_SIZE_MB=20